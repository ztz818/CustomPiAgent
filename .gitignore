# Project resources and large external assets
/resources/
/resoures/
.resources/

# Project-local caches
/.cache/
/npm_cache/
/uv_cache/
/conf/pi-agent/
/workspaces/*/.pi/agent/*
!/workspaces/*/.pi/agent/.gitkeep
/workspaces/*/uv_cache/
