# Runtime/user data
/drafts/
/data/
/webui/storage/
/workspaces/*/drafts/
/workspaces/*/logs/
/workspaces/*/projects/

# Logs can be generated locally during runs
/logs/*.log

# Common OS/editor noise
.DS_Store
*.swp
